# ============================================================
# Banking Models Store — Environment Variables
# ============================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to git — it contains secrets.
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# Email notifications (optional — uses nodemailer)
# To enable: npm install nodemailer, then fill in below.
#
# Gmail example (use an App Password, not your login password):
#   https://myaccount.google.com/apppasswords
#
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USER=your-email@gmail.com
# MAIL_PASS=your-app-password
# MAIL_TO=hello@bankingmodels.store
